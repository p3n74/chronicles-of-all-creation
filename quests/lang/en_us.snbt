		"Grades improve material quality — mediocre ore becomes intentional myth."































	]
	quest.1B78FF3D4E88AC57.title: "Azure Silver"
	quest.1B78FF3D4E88AC57.quest_subtitle: "The End's soft moonlight metal."
	quest.1B78FF3D4E88AC57.quest_desc: [































		"Mine Azure Silver Ore (netherite-tier harvest) and smelt Azure Silver Ingots."































		"Crimson steel or netherite coating gets you there. Moon Walker awaits."































	]
	quest.3213B6F83F9994D2.title: "Azure Electrum"
	quest.3213B6F83F9994D2.quest_subtitle: "Insane speed. Accelerate as it wears."
	quest.3213B6F83F9994D2.quest_desc: [































		"Craft Azure Electrum (azure silver + ender pearls + gold)."































		"Unlocks the Recrystallizer. Mining speed that laughs at geology."































	]
	quest.2B1369B97828DDFA.title: "Recrystallizer"
	quest.2B1369B97828DDFA.quest_subtitle: "Remake materials into better opinions."
	quest.2B1369B97828DDFA.quest_desc: [































		"Craft the Recrystallizer."































		"Late-game material alchemy for parties who refuse mediocre grades."































	]
	quest.68FD1D53F7CDA54D.title: "Starlight Ambition"
	quest.68FD1D53F7CDA54D.quest_subtitle: "Charge the myth until the stats blush."
	quest.68FD1D53F7CDA54D.quest_desc: [































		"Craft a Starlight Charger."































		"Big stat bonuses to materials — the Silent Forge's late hymn."































	]
	quest.364E24250D16CCBB.title: "Silent Emeritus"
	quest.364E24250D16CCBB.quest_subtitle: "Your gear has a birth certificate."
	quest.364E24250D16CCBB.quest_desc: [































		"Wear Silent Gear you forged yourself into a real fight."































		"Check when mass-produced steel feels like NPC cosplay."































	]
	quest.744C8D9CF3502BEE.title: "Gunsmith Manual"
	quest.744C8D9CF3502BEE.quest_subtitle: "Read before you reload."
	quest.744C8D9CF3502BEE.quest_desc: [



		"Obtain the Gunsmith Manual — jegn 1.7 dropped the old scrap workbench ladder."



		"This book is your table of contents for firearms that still exist in this build."



		"Open JEI. Search jeg. Believe the recipes, not the wiki fossils."



	]
	quest.3B625C236B78F952.title: "Crowbar Diplomacy"
	quest.3B625C236B78F952.quest_subtitle: "Guns jam. Crowbars don't negotiate."
	quest.3B625C236B78F952.quest_desc: [



		"Craft a Crowbar. Field repairs and stubborn crates prefer iron manners."



		"Keep one in the kit — the Ballad respects tools that don't need magazines."



		"If it is stuck, crowbar it. If it is jammed, crowbar nearby furniture for morale."



	]
	quest.25904A7F25583374.title: "Pipe Dream"
	quest.25904A7F25583374.quest_subtitle: "Humble thunder for humble heroes."
	quest.25904A7F25583374.quest_desc: [



		"Craft a Waterpipe Shotgun — the honest starter boomstick."



		"Ugly, loud, and registered. Unlike the ghosts of scrap ore."



		"This is the Ballad's first verse — check JEI for the iron-and-string hymn."



	]
	quest.2EAA0BD2EA0A445B.title: "Cylinder Gospel"
	quest.2EAA0BD2EA0A445B.quest_subtitle: "Six chambers of negotiation."
	quest.2EAA0BD2EA0A445B.quest_desc: [



		"Craft a Revolver. Close-range manners for iron-age gunfighters."



		"Pair it with Pistol Ammo before you practice on creepers."



		"Keep it oiled. Jams are comedy until they happen mid-raid."



	]
	quest.421559E1C8B17AB3.title: "Pistol Tithe"
	quest.421559E1C8B17AB3.quest_subtitle: "Copper, iron, gunpowder — democracy."
	quest.421559E1C8B17AB3.quest_desc: [



		"Craft 32 Pistol Ammo."



		"Pistols, revolvers, and several SMGs drink from this well."



		"Stockpile before the fight — mid-combat crafting is a skill issue."



	]
	quest.2C6DD489F61FB8EE.title: "Handmade Shells"
	quest.2C6DD489F61FB8EE.quest_subtitle: "Shotguns prefer homemade hospitality."
	quest.2C6DD489F61FB8EE.quest_desc: [



		"Craft Handmade Shells for early shotguns."



		"When the recipe book says shell, believe it."



		"Doorways and creepers both respect homemade hospitality."



	]
	quest.1C08800370494AE8.title: "Combat Sidearm"
	quest.1C08800370494AE8.quest_subtitle: "The pistol grows up."
	quest.1C08800370494AE8.quest_desc: [



		"Craft a Combat Pistol."



		"Faster arguments than the revolver — still drinks pistol ammo."



		"Holster pride; carry magazines."



	]
	quest.010F92AE1F8D228F.title: "Magazine Manners"
	quest.010F92AE1F8D228F.quest_subtitle: "Loose rounds are for amateurs."
	quest.010F92AE1F8D228F.quest_desc: [



		"Craft a Pistol Magazine."



		"Reload like a professional. Jam less. Brag more."



		"The Guild stamps dossiers for gunsmiths who stop dumping loose bullets on the floor."



	]
	quest.0F830E4858E7D6F2.title: "SMG Sermon"
	quest.0F830E4858E7D6F2.quest_subtitle: "Spray with intent."
	quest.0F830E4858E7D6F2.quest_desc: [



		"Craft a Custom SMG and an SMG Magazine."



		"Volume of fire is a love language — bring earplugs for the party."



		"Spray with intent. Ammo without a magazine is just optimistic gravel."



	]
	quest.0C90105D493C1CB1.title: "Pump Doctrine"
	quest.0C90105D493C1CB1.quest_subtitle: "Rack. Boom. Repeat."
	quest.0C90105D493C1CB1.quest_desc: [



		"Craft a Pump Shotgun and Shotgun Shells."



		"Doorways fear this verse of the Ballad."



		"Rack. Boom. Repeat. Polite knock-knocks are for people without shells."



	]
	quest.0D74BC4369A5F80D.title: "Rifle Doctrine"
	quest.0D74BC4369A5F80D.quest_subtitle: "Distance is a personality trait."
	quest.0D74BC4369A5F80D.quest_desc: [



		"Craft a Semi Auto Rifle and Rifle Ammo."



		"The horizon is now a valid conversation partner."



	]
	quest.2D6D6CCB9321A38D.title: "Stock Options"
	quest.2D6D6CCB9321A38D.quest_subtitle: "Shoulder the argument."
	quest.2D6D6CCB9321A38D.quest_desc: [



		"Craft a Makeshift Stock and attach it where JEI permits."



		"Recoil is optional if you pack furniture onto the gun."



		"Shoulder the argument — literally."



	]
	quest.3C3EAFCE893DDD56.title: "Sight Picture"
	quest.3C3EAFCE893DDD56.quest_subtitle: "Aim is not a rumor."
	quest.3C3EAFCE893DDD56.quest_desc: [



		"Craft a Reflex Sight."



		"Put glass between you and bad decisions."



		"Hip-firing is a lifestyle; aiming is a career."



	]
	quest.1FF9C2CF689A5D7B.title: "Grip Gospel"
	quest.1FF9C2CF689A5D7B.quest_subtitle: "Control the muzzle or it controls you."
	quest.1FF9C2CF689A5D7B.quest_desc: [



		"Craft a Light Grip."



		"Attachments are how amateurs become annoyingly accurate."



		"Control the muzzle or it writes your memoir in the dirt."



	]
	quest.593F7D27EBE72E45.title: "Repair Creed"
	quest.593F7D27EBE72E45.quest_subtitle: "Durability is a fuse. Mending is faith."
	quest.593F7D27EBE72E45.quest_desc: [



		"Craft a Gun Repair Kit."



		"Jams love low durability — keep the kit closer than your pride."



		"Enchantments help; repair kits are honest."



	]
	quest.56FB5CF6454E2CBE.title: "Flare Writ"
	quest.56FB5CF6454E2CBE.quest_subtitle: "Signal the sky. Or the raid."
	quest.56FB5CF6454E2CBE.quest_desc: [



		"Craft a Flare Gun and a Flare."



		"Useful for visibility, drama, and telling allies where the screaming is."



	]
	quest.322C7590812F4889.title: "Plate Carrier"
	quest.322C7590812F4889.quest_subtitle: "Fashion that stops lead."
	quest.322C7590812F4889.quest_desc: [



		"Craft Bulletproof Vest I."



		"The Ballad prefers living narrators. Armor helps."



		"Fashion that stops lead — upgrade tiers later when the raids get opinions."



	]
	quest.02B8416D6A9390CE.title: "Assault Writ"
	quest.02B8416D6A9390CE.quest_subtitle: "When semi-auto feels polite."
	quest.02B8416D6A9390CE.quest_desc: [



		"Craft an Assault Rifle."



		"Mid-to-late thunder for parties who brought magazines and a plan."



		"When semi-auto feels polite, this is the louder paragraph."



	]
	quest.733A7B907267C0DF.title: "Spectre Armory"
	quest.733A7B907267C0DF.quest_subtitle: "Pretty name. Unpretty muzzle flash."
	quest.733A7B907267C0DF.quest_desc: [



		"Craft the Blossom Rifle — a high-end spectre firearm still registered in jegn."



		"If JEI asks for strange reagents, follow JEI. Wiki fossils lie."



		"Pretty name. Unpretty muzzle flash. Bring magazines anyway."



	]
	quest.348C62A8ACF6B390.title: "Holy Boom"
	quest.348C62A8ACF6B390.quest_subtitle: "Blessed pellets for unholy hours."
	quest.348C62A8ACF6B390.quest_desc: [



		"Craft the Holy Shotgun."



		"Pair with the Blossom path — two hymns, one gunsmith."



		"Blessed pellets for unholy hours. Amen, and reload."



	]
	quest.094605D40953CD90.title: "Gunsmith Emeritus"
	quest.094605D40953CD90.quest_subtitle: "The ballad ends with a reload."
	quest.094605D40953CD90.quest_desc: [



		"Keep a Repair Kit and your Gunsmith Manual in the kit."



		"Check when you can arm, armor, attach, and repair without asking the Guide twice."



	]
	chapter.245AFA584EC04BFE.title: "&eSkywright's Leviathan"
	chapter.245AFA584EC04BFE.chapter_subtitle: "Create Aeronautics — lift, thrust, cannons, flying hold"
	quest.3865975115E979CD.title: "Aviator's Writ"
	quest.3865975115E979CD.quest_subtitle: "See stress. See weight. See destiny."
	quest.3865975115E979CD.quest_desc: [

		"Craft Aviator's Goggles — the Skywright's upgraded Engineer's Goggles."

		"Wiki: they show SU, block weight, and physics tips when you look at components."

		"Wear them. The Leviathan begins as information, not timber."

	]
	quest.35E418F82612554B.title: "Honey Compact"
	quest.35E418F82612554B.quest_subtitle: "Super Glue's ambitious cousin."
	quest.35E418F82612554B.quest_desc: [

		"Craft Honey Glue (spout honey onto an iron sheet — check JEI)."

		"Wiki: selection works like Schematic \\& Quill — Alt corner, Ctrl+scroll faces."

		"Overlapping honey regions merge on assemble. Barely-touching regions do not."

	]
	quest.015FAB8E412245D7.title: "Physics Assembler"
	quest.015FAB8E412245D7.quest_subtitle: "The altar where blocks become a body."
	quest.015FAB8E412245D7.quest_desc: [

		"Craft a Physics Assembler — Simulated's core assembly block."

		"Wiki: it grabs itself and the block below; honey/super glue regions ride along."

		"Large ships outgrow the block limit — assemble, then build outward on the live hull."

	]
	quest.625AF8C0F9040CA4.title: "Diagram of Forces"
	quest.625AF8C0F9040CA4.quest_subtitle: "Lift, thrust, and regret — visualized."
	quest.625AF8C0F9040CA4.quest_desc: [

		"Craft a Contraption Diagram."

		"Wiki: right-click a simulated contraption to visualize forces acting on it."

		"Use it before you blame the sky. The sky keeps receipts."

	]
	quest.051E6EF9F6ECC0BA.title: "First Physics"
	quest.051E6EF9F6ECC0BA.quest_subtitle: "Confirm the world still has laws."
	quest.051E6EF9F6ECC0BA.quest_desc: [

		"Honey-glue a tiny platform, place the Assembler, and throw the assemble lever."

		"Disassemble and reassemble once. Check when the physics body feels real."

		"Creative test pads are legal. Crashing your survival base is a lifestyle choice."

	]
	quest.7D9938A37FEAE404.title: "Grab Handle"
	quest.7D9938A37FEAE404.quest_subtitle: "Hold the ship before it holds you."
	quest.7D9938A37FEAE404.quest_desc: [

		"Craft an Iron Handle (or any dyed Handle)."

		"Wiki: hold right-click to grab; sneak-grab moves the contraption; scroll adjusts distance."

		"Mount handles where crew need to haul, dock, or panic with dignity."

	]
	quest.5D44EAC4AA855E15.title: "Engine Assembly"
	quest.5D44EAC4AA855E15.quest_subtitle: "Saw. Press. Repeat. Become loud."
	quest.5D44EAC4AA855E15.quest_desc: [

		"Craft an Engine Assembly (Create pressing/sawing chain on iron sheets — JEI)."

		"This is the heart of every Portable Engine. Keep extras; ships eat hearts."

	]
	quest.25FC28261B5D9D9B.title: "Portable Heart"
	quest.25FC28261B5D9D9B.quest_subtitle: "Onboard RPM without a windmill farm."
	quest.25FC28261B5D9D9B.quest_desc: [

		"Craft a Portable Engine (Blast Furnace + Engine Assembly + Iron Sheet)."

		"Wiki: furnace fuels work; Blaze Cakes superheat — 2048 SU @ 32 RPM, or 4096 @ 64."

		"Mount it on the hull. Belts and shafts are still Create — only the floor is freer."

	]
	quest.4306BD765C3F8532.title: "Envelope Tithe"
	quest.4306BD765C3F8532.quest_subtitle: "Wool and sticks become sky."
	quest.4306BD765C3F8532.quest_desc: [

		"Craft 32 Hot Air Envelopes (white / undyed)."

		"Wiki: two wool + two sticks → four envelopes. Dye later; airtight volume first."

		"Envelopes bounce fall damage — useful when your prototype becomes a teaching moment."

	]
	quest.4D5BAD95FA0C9B3A.title: "Hot Air Burner"
	quest.4D5BAD95FA0C9B3A.quest_subtitle: "Redstone fills the balloon. No coal required."
	quest.4D5BAD95FA0C9B3A.quest_desc: [

		"Craft a Hot Air Burner (Adjustable Burner)."

		"Wiki: powered by redstone; fills enclosed envelope volume from the top down."

		"Side panels set max volume (5–500 m³). Signal strength scales fill toward that max."

	]
	quest.5E57EACE2BBE23DE.title: "Balloon Prototype"
	quest.5E57EACE2BBE23DE.quest_subtitle: "Hover is a personality trait."
	quest.5E57EACE2BBE23DE.quest_desc: [

		"Build an airtight envelope balloon over a Hot Air Burner on a simulated hull."

		"Power the burner. Confirm lift on the Contraption Diagram. Land without a crater."

		"Check when you can take off, hover, and settle on the same pad."

	]
	quest.1EEF635B11B21F6B.title: "Wooden Propeller"
	quest.1EEF635B11B21F6B.quest_subtitle: "Two blades. Honest thrust."
	quest.1EEF635B11B21F6B.quest_desc: [

		"Craft a Wooden Propeller — early directional thrust."

		"Spin it from behind with Create kinetics. Point the face where you want to go."

		"Light craft only. Leviathans will laugh — then demand andesite."

	]
	quest.5B0792CFFC7BAD6A.title: "Andesite Propeller"
	quest.5B0792CFFC7BAD6A.quest_subtitle: "Four blades. Real ambitions."
	quest.5B0792CFFC7BAD6A.quest_desc: [

		"Craft an Andesite Propeller."

		"Wiki: ~31.4 propulsion units at 32 RPM; SU cost scales as 4 × RPM."

		"Pair with a Portable Engine. Balance thrust below the center of lift or enjoy looping."

	]
	quest.52D96346CF2D60B1.title: "Propeller Bearing"
	quest.52D96346CF2D60B1.quest_subtitle: "Spin a whole sail-disk, not one lonely blade."
	quest.52D96346CF2D60B1.quest_desc: [

		"Craft a Propeller Bearing."

		"Wiki: needs rotational power from the back; attach ≥2 sail-like blocks (sails/wool)."

		"Thrust scales with sails and RPM. Side-configure thrust direction. No unwanted torque!"

	]
	quest.1D4C0F3C88607AF1.title: "Symmetric Sail"
	quest.1D4C0F3C88607AF1.quest_subtitle: "Canvas that means business."
	quest.1D4C0F3C88607AF1.quest_desc: [

		"Craft Symmetric Sails for propeller assemblies (or dye a white one)."

		"Mount at least two on a Propeller Bearing. Pretty ships still need physics."

	]
	quest.3CCE4EB7B679768B.title: "Helm \\& Throttle"
	quest.3CCE4EB7B679768B.quest_subtitle: "Hands on the sky."
	quest.3CCE4EB7B679768B.quest_desc: [

		"Craft a Steering Wheel and a Throttle Lever."

		"Wiki: hold use on the wheel — mouse yaw becomes shaft rotation (Shift snaps 45°)."

		"Throttle governs analog power to engines/propellers. Label your bridge like adults."

	]
	quest.2467BE74B8A6C8AE.title: "First Free Flight"
	quest.2467BE74B8A6C8AE.quest_subtitle: "Leave the pad. Return with a story."
	quest.2467BE74B8A6C8AE.quest_desc: [

		"Fly a craft with lift (balloon and/or props) plus forward thrust and helm control."

		"Travel to a distant biome landmark and return. No creative flight cheats."

		"Check when the Diagram no longer looks like a crime scene."

	]
	quest.373A97E5C210B54F.title: "Gyroscopic Mechanism"
	quest.373A97E5C210B54F.quest_subtitle: "Brass that remembers upright."
	quest.373A97E5C210B54F.quest_desc: [

		"Craft a Gyroscopic Mechanism (Create sequencing — JEI)."

		"Required for Gyroscopic Propeller Bearings — the stabilizer of serious hulls."

	]
	quest.337FF5E921E58CD6.title: "Gyro Bearing"
	quest.337FF5E921E58CD6.quest_subtitle: "Auto-leveling for people who hate rolling."
	quest.337FF5E921E58CD6.quest_desc: [

		"Craft a Gyroscopic Propeller Bearing (slab + Gyro Mechanism + Brass Casing)."

		"Wiki: tilts up to 12° to fight pitch/roll when props sit above/below CoM."

		"Redstone lock freezes it into a normal Propeller Bearing. Use for combat runs."

	]
	quest.29559F644DF042DF.title: "Smart Propeller"
	quest.29559F644DF042DF.quest_subtitle: "Thrust that tries to look at the sky."
	quest.29559F644DF042DF.quest_desc: [

		"Craft a Smart Propeller."

		"Wiki: generates thrust when spun; pitches to face upwards; wrench reverses thrust."

		"Excellent for VTOL attitudes and mid-air attitude recovery on fat hulls."

	]
	quest.73BFDEAB6367980F.title: "Steam Vent"
	quest.73BFDEAB6367980F.quest_subtitle: "Boilers can fill balloons too."
	quest.73BFDEAB6367980F.quest_desc: [

		"Craft a Steam Vent — alternate lift source for envelope volumes."

		"Wiki: multiple vents/burners can fill the same balloon, stacking speed and volume."

		"Route Create steam like a civilized skywright. Condensation is for groundlings."

	]
	quest.3BD92E0B1BD2F512.title: "End Dust"
	quest.3BD92E0B1BD2F512.quest_subtitle: "The void's baking flour."
	quest.3BD92E0B1BD2F512.quest_desc: [

		"Obtain End Stone Powder — Levitite feedstock."

		"Bring the End's dust home. The Leviathan's magic keel starts as powder."

	]
	quest.0F3A60B9E856FDA0.title: "Levitite Blend"
	quest.0F3A60B9E856FDA0.quest_subtitle: "Heated mixing. Floating ambition."
	quest.0F3A60B9E856FDA0.quest_desc: [

		"Produce Levitite Blend (heated mixing — wiki: powders/fluids per JEI)."

		"Bucket it. Pour molds. Keep clay sacrificial — curing breaks clay forms."

	]
	quest.787391AFA4B5986A.title: "Levitite Keel"
	quest.787391AFA4B5986A.quest_subtitle: "Anti-gravity for battleship mass."
	quest.787391AFA4B5986A.quest_desc: [

		"Cure Levitite: place blend source blocks, light fire/campfire nearby."

		"Wiki: 10kpg anti-gravity + unique low-speed drag. Soul fire → Pearlescent variant."

		"Stockpile Levitite blocks under the deck. Heavy guns need magic buoyancy."

	]
	quest.616E483A52D4A9E6.title: "Name the Leviathan"
	quest.616E483A52D4A9E6.quest_subtitle: "Untitled ships sink in the paperwork."
	quest.616E483A52D4A9E6.quest_desc: [

		"Craft a Nameplate and set the contraption's name."

		"Wiki: right-click to edit; dye recolors; honeycomb locks; plates sync the ship name."

		"Pick a name you would paint on the prow before the cannons go loud."

	]
	quest.7902D7345C75A8D5.title: "Navigation Table"
	quest.7902D7345C75A8D5.quest_subtitle: "Charts for people who refuse to get lost at altitude."
	quest.7902D7345C75A8D5.quest_desc: [

		"Craft a Navigation Table for the bridge."

		"Mount it near helm and throttle. Portable bases need a place to plan the next raid."

	]
	quest.087D3491C42EF3C3.title: "Linked Bridge"
	quest.087D3491C42EF3C3.quest_subtitle: "Fly from a chair. Or a panic room."
	quest.087D3491C42EF3C3.quest_desc: [

		"Craft a Linked Typewriter."

		"Wiki: bind redstone-link frequencies to keys; Linked Controller copies bindings."

		"Wire burners, prop locks, and cannon safeties. Remote command is a survival trait."

	]
	quest.7E19078A2E48238E.title: "Docking Writ"
	quest.7E19078A2E48238E.quest_subtitle: "Airports are optional. Latches are not."
	quest.7E19078A2E48238E.quest_desc: [

		"Craft a Docking Connector (and preferably a Paired Docking Connector)."

		"Secure the Leviathan to a tower, cliff, or sister ship without creative praying."

	]
	quest.12795FC983D9996F.title: "Potato Broadside"
	quest.12795FC983D9996F.quest_subtitle: "Practice ordnance for polite skies."
	quest.12795FC983D9996F.quest_desc: [

		"Craft a Mounted Potato Cannon (Aeronautics)."

		"Test gun mounts and recoil manners before you weld real CBC steel to the hull."

	]
	quest.785BF613A6584868.title: "Cannon Mount"
	quest.785BF613A6584868.quest_subtitle: "RPM aims what shoulders should not."
	quest.785BF613A6584868.quest_desc: [

		"Craft a Create Big Cannons Cannon Mount."

		"Bolt it to the simulated deck. Kinetic aiming belongs on a battleship."

		"Siegewrights chapter recommended — but the Leviathan demands its own mount."

	]
	quest.15CD482A48FAF679.title: "Siege Heart"
	quest.15CD482A48FAF679.quest_subtitle: "Chamber and end — shipboard edition."
	quest.15CD482A48FAF679.quest_desc: [

		"Craft a Wrought Iron Cannon Chamber and Cannon End for the first broadside gun."

		"Assemble on the mount with powder and shot. Prefer the horizon to friendly balloons."

	]
	quest.39A174F851F77083.title: "Flying Hold"
	quest.39A174F851F77083.quest_subtitle: "A base that moves when the map gets rude."
	quest.39A174F851F77083.quest_desc: [

		"Outfit the Leviathan as a portable hold: bed/spawn, storage chests, crafting/Create station,"

		"food stores, and a Waystone or return plan. Live aboard for a full day-night cycle."

		"Check when the ship is home — not a joyride with cannons."

	]
	quest.350802CBF25986A4.title: "Leviathan Emeritus"
	quest.350802CBF25986A4.quest_subtitle: "Battleship. Base. Ballad complete."
	quest.350802CBF25986A4.quest_desc: [

		"Prove the full Skywright doctrine: Levitite-buoyed (or balloon) hull, propulsion, helm,"

		"at least one mounted CBC gun that can fire, and a livable interior."

		"Fly a combat patrol and return to dock. Check when the Guide stamps your airship papers."

	]
	chapter.41A78F8BDE9CA7B6.title: "&eHymn of Eternal Starlight"
	chapter.41A78F8BDE9CA7B6.chapter_subtitle: "Eternal Starlight — Gatekeeper → biomes → Golem \\& Monstrosity → Unrealium"
	quest.22C744D4141B42A4.title: "Challenge the Gatekeeper"
	quest.22C744D4141B42A4.quest_subtitle: "Portal Ruins. He attacks on sight."
	quest.22C744D4141B42A4.quest_desc: [
		"Find Overworld Portal Ruins — Common, Cold, Desert, Forest, or Jungle variants."
		"The Gatekeeper has ~175 HP. Meteors, dash-stabs, ground slams. Mid-range + shield."
		"You need not kill him — force submission. Open the Loot Bag for the Orb of Prophecy."
		"Iron/Diamond gear minimum. Bring food, blocks, and patience for falling rocks."
	]
	quest.3373AACDE62A4A24.title: "Glimmering Tablet"
	quest.3373AACDE62A4A24.quest_subtitle: "Read before you step through."
	quest.3373AACDE62A4A24.quest_desc: [
		"Claim the Glimmering Tablet (Starlight Story book) from the Gatekeeper's bag."
		"It sketches biomes, boss tracking, and why Lunar Berries matter later."
		"Also pocket Seeking Eyes and the Keeper Armor Trim if the bag is generous."
	]
	quest.7ED2409DA9F68439.title: "Clear the Frame"
	quest.7ED2409DA9F68439.quest_subtitle: "Torreya Vines block ignition."
	quest.7ED2409DA9F68439.quest_desc: [
		"Break every Torreya Vine on the portal frame before activation."
		"Vines left behind silently fail the ritual — clear first, then ignite."
		"Keep a stack; vines also appear around Torreya wood in the dimension."
	]
	quest.329FF7502F591C3C.title: "Starlight Crossing"
	quest.329FF7502F591C3C.quest_subtitle: "A sky that isn't ours."
	quest.329FF7502F591C3C.quest_desc: [
		"Main-hand the Orb of Prophecy. Right-click the top dark portal blocks."
		"Enter eternal_starlight:starlight. Bring Lunar Berries home as passport proof."
		"Stock food, fire resistance manners, and a pickaxe before you commit."
		"Disable heavy shaders briefly if you cannot see the activation particles."
	]
	quest.38BA25ECEBFEB5A2.title: "Seeking Eye"
	quest.38BA25ECEBFEB5A2.quest_subtitle: "Ender Eyes for a foreign sky."
	quest.38BA25ECEBFEB5A2.quest_desc: [
		"Craft Seeking Eyes from Starlight Flowers that grow across the dimension."
		"Throw while holding the correct off-hand bait:"
		"  • Redstone → Starlight Golem / Golem Forge"
		"  • Lunar Berries → Lunar Monstrosity / Cursed Garden"
		"Follow where the eye lands, then dig. Structure rings of Voidstone mark forges above ground."
	]
	quest.72C7D5D05B8E785E.title: "Way Home in Voidstone"
	quest.72C7D5D05B8E785E.quest_subtitle: "The portal does not follow you."
	quest.72C7D5D05B8E785E.quest_desc: [
		"Mine Voidstone underground. Craft Chiseled Voidstone and rebuild the frame exactly."
		"Ignite the return portal with the Orb of Prophecy — it is not consumed."
		"Do this before deep boss runs. Getting stranded is a lore choice, not a strategy."
	]
	quest.7772E37B1DB1B24E.title: "Deepsilver Tithe"
	quest.7772E37B1DB1B24E.quest_subtitle: "Faster than diamond. Swamp mud remembers."
	quest.7772E37B1DB1B24E.quest_desc: [
		"Mine Deepsilver Ore in Grimstone, Voidstone, ice layers, and Nightfall Mud — Dark Swamp helps."
		"Smelt Deepsilver Ingots. Tools mine fast (~12); armor grants speed and knockback resistance."
		"This metal is also an Unrealium alloy ingredient. Stockpile early."
	]
	quest.64F67C815E80AB56.title: "Thermal Springstone"
	quest.64F67C815E80AB56.quest_subtitle: "Fire manners for a fire-immune boss later."
	quest.64F67C815E80AB56.quest_desc: [
		"Gather Thermal Springstone (lakes / forge loot / ore) and smelt Thermal Springstone Ingots."
		"Armor reduces fire damage and scorches nearby mobs — excellent Lunar Monstrosity prep."
		"Hammer hits hard and slow. Starfire Upgrade Templates (Golem loot) push this tier further."
	]
	quest.49B6D8EF5BD848C8.title: "Glacite Harvest"
	quest.49B6D8EF5BD848C8.quest_subtitle: "Permafrost caves keep giant crystals."
	quest.49B6D8EF5BD848C8.quest_desc: [
		"Descend beneath the Starlight Permafrost Forest. Mine Glacite crystal formations."
		"One crystal yields many Glacite Shards. Armor and weapons freeze attackers."
		"Mandatory manners for Freeze mobs guarding the Golem Forge — leather boots help too."
	]
	quest.28E20A49D0926516.title: "Malarite Vein"
	quest.28E20A49D0926516.quest_subtitle: "Poison arrows and alloy fuel."
	quest.28E20A49D0926516.quest_desc: [
		"Mine Malarite from Grimstone, Voidstone, and Nightfall Mud cave layers."
		"Fast melee weapons; Malarite Arrows inflict Poison. No armor tier — offense only."
		"Required for Unrealium in the Alloy Furnace. Do not skip the stockpile."
	]
	quest.2C8D4458E209C1E3.title: "Starlit Diamond"
	quest.2C8D4458E209C1E3.quest_subtitle: "Toughness that outranks vanity."
	quest.2C8D4458E209C1E3.quest_desc: [
		"Mine Starlit Diamond Ore in Grimstone, Voidstone, Eternal Ice, or Haze Ice caves."
		"Smelt Starlit Diamonds — ~2500 durability, high toughness armor (20 / 3.0)."
		"Best pre-alloy armor set. Wear it into the Cursed Garden without shame."
	]
	quest.353926765613D2ED.title: "Glacite Shield"
	quest.353926765613D2ED.quest_subtitle: "Freeze the things that freeze you."
	quest.353926765613D2ED.quest_desc: [
		"Craft a Glacite Shield from your shard harvest."
		"It can freeze attacking mobs solid — strongest shield in the mod."
		"Bring it to the Golem Forge. Freeze projectiles kill prideful pilgrims."
	]
	quest.29C1FEE87E215629.title: "Tooth of Hunger"
	quest.29C1FEE87E215629.quest_subtitle: "Crystallized Desert collects debts."
	quest.29C1FEE87E215629.quest_desc: [
		"Hunt Thirst Walkers in the Crystallized Desert for a Tooth of Hunger."
		"Red/Blue Starlight Crystal clusters here also feed Mana Crystal crafting."
		"Twilight Sand builds pretty tombs. The Tooth builds something hungrier."
	]
	quest.0D1E169FEDE89CA0.title: "Dagger of Hunger"
	quest.0D1E169FEDE89CA0.quest_subtitle: "Feed it kills — or it feeds on you."
	quest.0D1E169FEDE89CA0.quest_desc: [
		"Craft the Dagger of Hunger from the Tooth."
		"It must be fed with kills. Neglect its appetite and it drains your health."
		"Living weapons keep their own ledgers. Stay current."
	]
	quest.1CD201F38ACEF115.title: "Thioquartz Vigil"
	quest.1CD201F38ACEF115.quest_subtitle: "Ether River is not a swimming hole."
	quest.1CD201F38ACEF115.quest_desc: [
		"Harvest Thioquartz Shards near Ether fluid biomes."
		"Ether deals continuous damage. Do not dive for souvenirs without protection."
		"Alchemist gear from Thioquartz grants Ether Resistance for Flowglaze work."
	]
	quest.7BCB3F1CFD32AA29.title: "Alchemist Mask"
	quest.7BCB3F1CFD32AA29.quest_subtitle: "Breathe where the river bites."
	quest.7BCB3F1CFD32AA29.quest_desc: [
		"Craft an Alchemist Mask (Thioquartz set) before serious Ether work."
		"Ether Resistance turns a death biome into a quarry."
		"Finish the robe set if you plan long Flowglaze harvests."
	]
	quest.774481985300429D.title: "Flowglaze Prize"
	quest.774481985300429D.quest_subtitle: "Where Ether kisses water."
	quest.774481985300429D.quest_desc: [
		"Collect Flowglaze that forms where Ether fluid contacts water."
		"Wear Alchemist protection. Pocket the quartz-like blocks for Flowglaze tools/scythes."
		"Optional late vanity: Flowglaze Scythe looks like it belongs in a hymn."
	]
	quest.07C2E525E9912D79.title: "Golem Steel Hymn"
	quest.07C2E525E9912D79.quest_subtitle: "Disable generators. Dodge the beam. Smelt the rust."
	quest.07C2E525E9912D79.quest_desc: [
		"Track the Golem Forge: Seeking Eye + Redstone off-hand. Surface Voidstone rings mark it."
		"Right-click Energy Generators to drop the Starlight Golem's shield, then burst damage."
		"When arms rise — RUN. The light beam ignores armor. Freezes in the forge hate the unprepared."
		"Loot Bag drops Oxidized Golem Steel — smelt into Golem Steel Ingots. Bring one home."
	]
	quest.59EE188E81425F05.title: "Chain of Souls"
	quest.59EE188E81425F05.quest_subtitle: "Set it on fire — or deal zero forever."
	quest.59EE188E81425F05.quest_desc: [
		"Track the Cursed Garden: Seeking Eye + Lunar Berries off-hand. Huge underground maze."
		"Lunar Monstrosity is immune until ignited (Fire Aspect, flaming arrows, fire charges)."
		"Kill/control the Tangled Hatred tentacle. Retreat into maze corridors to heal."
		"Loot Bag proof: Chain of Souls — 64-block whip that drinks souls. Claim it."
	]
	quest.7D5092D44BBBF890.title: "Crescent Spear"
	quest.7D5092D44BBBF890.quest_subtitle: "Riptide without the thunderstorm tax."
	quest.7D5092D44BBBF890.quest_desc: [
		"Obtain the Crescent Spear — Lunar Monstrosity progression prize / craft path after the garden."
		"Permanent Riptide in any weather. Mobility turns the starlight map into a commute."
		"Pair with Chain of Souls for pull-and-punish manners."
	]
	quest.482EE8A4495892EE.title: "Soul Dew"
	quest.482EE8A4495892EE.quest_subtitle: "Garden dew for endgame alloy."
	quest.482EE8A4495892EE.quest_desc: [
		"Collect Soul Dew from Lunar Monstrosity loot / Cursed Garden spoils."
		"Required Unrealium ingredient alongside Deepsilver, Golem Steel, and Malarite."
		"Nightfall Spider Eyes + Soul Dew also craft the Soulit Spectator scouting tool."
	]
	quest.336196B4C5DF8E32.title: "Aethersent Ingot"
	quest.336196B4C5DF8E32.quest_subtitle: "Meteor showers mint foreign iron."
	quest.336196B4C5DF8E32.quest_desc: [
		"Obtain Aethersent Ingots — Creteor kills during meteor showers (or related sky events)."
		"Aethersent armor answers damage with falling meteors. Highest enchantability in the mod."
		"Starfall Longbow recipes use Creteor Hide. Keep scraps."
	]
	quest.44CBC8233F991659.title: "Aetherstrike Rocket"
	quest.44CBC8233F991659.quest_subtitle: "Schedule the sky's temper tantrum."
	quest.44CBC8233F991659.quest_desc: [
		"Craft or claim an Aetherstrike Rocket to trigger a meteor shower on demand."
		"Farm Creteors and Aethersent without waiting on celestial calendars."
		"Warn the party before launch. Falling stars do not check friend lists."
	]
	quest.0BB545C37E1248B1.title: "Alloy Furnace"
	quest.0BB545C37E1248B1.quest_subtitle: "Mix the hymn's metals — watch the heat."
	quest.0BB545C37E1248B1.quest_desc: [
		"Craft the Alloy Furnace. Synthesize Unrealium from Deepsilver + Golem Steel + Malarite + Soul Dew."
		"Do not leave it running past ~10 minutes — overheat explodes (~3 block radius)."
		"Wax with Raw Amaramber or Honeycomb for a decorative Waxed Alloy Furnace if desired."
	]
	quest.4AF68676C6A86069.title: "Unrealium Crown"
	quest.4AF68676C6A86069.quest_subtitle: "Fastest tools. End of the metal hymn."
	quest.4AF68676C6A86069.quest_desc: [
		"Alloy an Unrealium Ingot. Mining speed 15 — top craftable tier in Eternal Starlight."
		"Armor ties Starlit Diamond at 20 points. Crossbow and full set are late flexes."
		"Wear Unrealium into any remaining structure and rewrite the ledger."
	]
	quest.1CEEB4C1944F28FE.title: "Mana Crystal Chorus"
	quest.1CEEB4C1944F28FE.quest_subtitle: "Orb of Prophecy doubles as a wand."
	quest.1CEEB4C1944F28FE.quest_desc: [
		"Craft a Mana Crystal from the six elemental crystals (Terra/Wind/Water/Lunar/Blaze/Light)."
		"Red Starlight Crystal Shards from the Crystallized Desert are the common feedstock."
		"Hold the Orb, cycle crests (default I), cast with charged Mana Crystal in inventory."
		"Blazing Beam (Golem crest path) is the signature laser — run the same manners you feared."
	]
	quest.16AEADFFF8CF624E.title: "Starlight Emeritus"
	quest.16AEADFFF8CF624E.quest_subtitle: "The hymn ends when you can leave — and return."
	quest.16AEADFFF8CF624E.quest_desc: [
		"You opened ruins, stamped Lunar Berries, armed with Deepsilver/Glacite/Thermal,"
		"silenced the Golem Forge, burned the Lunar Monstrosity, and forged Unrealium."
		"Check when Orb, Seeking Eyes, return Voidstone portal, and Unrealium gear are routine."
		"Depths \\& Realms still stamps the passport — this chapter taught you the country."
	]
}
